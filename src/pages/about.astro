---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config';
---

<Layout title={`About - ${SITE_CONFIG.title}`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-center uppercase text-gray-600 dark:text-gray-400 mb-6">
      About me
    </h1>

    <!-- Icon Divider -->
    <div class="divider-custom">
      <div class="divider-custom-line"></div>
      <div class="divider-custom-icon">
        <svg
          width="0.5em"
          height="0.5em"
          viewBox="0 0 16 16"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.283.95l-3.523 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"
          />
        </svg>
      </div>
      <div class="divider-custom-line"></div>
    </div>

    <div class="flex flex-col items-center text-gray-600 dark:text-gray-400 mt-8">
      <div class="w-full space-y-6 text-gray-700 dark:text-gray-300 leading-relaxed">
        <p>
          Welcome! This is a sample about page for the Pulsar theme. Replace this content with your own story, background, and what makes you unique.
        </p>
        <p>
          This theme is built with <strong>Astro</strong> and <strong>Tailwind CSS</strong>. It ships with dark mode, syntax highlighting, an RSS feed, tag pages, reading time estimates, previous/next post navigation, SEO optimization, optional analytics, accessibility features, and responsive design out of the box.
        </p>
        <p>
          Customize this page by editing <code>src/pages/about.astro</code>. Update your site information in <code>src/config.ts</code> to personalize the entire theme with your details.
        </p>
        {SITE_CONFIG.socialLinks.github && (
          <p>
            Find me on GitHub:{' '}
            <a
              href={`https://github.com/${SITE_CONFIG.socialLinks.github}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 dark:text-blue-400 hover:underline"
            >
              @{SITE_CONFIG.socialLinks.github}
            </a>
          </p>
        )}
      </div>
    </div>
  </div>
</Layout>
