---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config';
---

<Layout title={`About - ${SITE_CONFIG.title}`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-center uppercase text-gray-600 dark:text-gray-400 mb-6">
      About me
    </h1>

    <!-- Icon Divider -->
    <div class="divider-custom">
      <div class="divider-custom-line"></div>
      <div class="divider-custom-icon">
        <svg
          width="0.5em"
          height="0.5em"
          viewBox="0 0 16 16"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.283.95l-3.523 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"
          />
        </svg>
      </div>
      <div class="divider-custom-line"></div>
    </div>

    <div class="flex flex-col items-center text-gray-600 dark:text-gray-400 mt-8">
      <div class="w-full space-y-6 text-gray-700 dark:text-gray-300 leading-relaxed">
	  <div>
		              <p>
                I'm a mechatronic engineer working in industrial automation and
                PLC software engineering. KineticCode is my engineering log — a
                space dedicated to bridging the gap between physical systems,
                robust software architectures, and functional prototyping.
              </p>
              <p>
                My background spans from developing real-time industrial
                software to building custom C++ applications.
                I focus on how logic interacts with physical motion,
                prioritizing clean, deterministic systems over superficial
                trends.
              </p>
              <p>
                When I'm not programming controllers or refactoring C++
                codebases, I'm usually designing functional mechanisms in CAD
                and bringing them to life through 3D printing.
              </p>
            </div>
        {SITE_CONFIG.socialLinks.github && (
          <p>
            Find me on GitHub:{' '}
            <a
              href={`https://github.com/${SITE_CONFIG.socialLinks.github}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 dark:text-blue-400 hover:underline"
            >
              @{SITE_CONFIG.socialLinks.github}
            </a>
          </p>         
        )}
        <p>
          Read my articles on Substack:{' '}
          <a
            href="https://kineticcode.substack.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 dark:text-blue-400 hover:underline"
          >
            KineticCode
          </a>
        </p>
      </div>
    </div>
  </div>
</Layout>
