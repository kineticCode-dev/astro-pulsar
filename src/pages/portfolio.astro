---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config';

// Replace these placeholder projects with your own work.
const projects = [
  {
    title: 'Project One',
    url: 'https://example.com',
    description:
      'A short elevator pitch for your project: what it does and who it is for. Keep it to a sentence or two.',
    details:
      'A little more depth: the problem it solves, an interesting technical decision, or what you learned building it.',
    gradient: 'from-purple-600 to-blue-600',
    tags: [
      { label: 'Astro', color: 'bg-red-500' },
      { label: 'TypeScript', color: 'bg-blue-500' },
      { label: 'Tailwind CSS', color: 'bg-teal-500' },
    ],
  },
  {
    title: 'Project Two',
    url: 'https://github.com/username/project-two',
    description:
      'Another project summary. Link the card header to a live demo or the repository.',
    details:
      'Swap the gradient colors per project to give each card its own identity, and keep tech tags to the essentials.',
    gradient: 'from-emerald-600 to-cyan-600',
    tags: [
      { label: 'Node.js', color: 'bg-green-600' },
      { label: 'TypeScript', color: 'bg-blue-500' },
      { label: 'PostgreSQL', color: 'bg-indigo-500' },
    ],
  },
];
---

<Layout title={`Portfolio - ${SITE_CONFIG.title}`} description="Selected projects and work">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-4xl font-bold text-center mb-12 text-gray-900 dark:text-gray-100">Portfolio</h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {projects.map((project) => (
        <div class="bg-gray-50 dark:bg-gray-700 rounded-lg shadow-md overflow-hidden transition-colors duration-200">
          <div class="md:flex md:flex-col bg-gray-50 dark:bg-gray-700">
            <div class="md:flex-shrink-0">
              <a href={project.url} target="_blank" rel="noopener noreferrer">
                <div class={`h-48 w-full bg-gradient-to-br ${project.gradient} flex items-center justify-center`}>
                  <svg class="w-24 h-24 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                </div>
              </a>
            </div>
            <div class="p-8 bg-gray-50 dark:bg-gray-700 flex-1 transition-colors duration-200">
              <h5 class="text-2xl font-semibold mb-3 text-gray-900 dark:text-gray-100">{project.title}</h5>
              <p class="text-gray-700 dark:text-gray-300 mb-3">{project.description}</p>
              <p class="text-gray-600 dark:text-gray-400 mb-4">{project.details}</p>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">Technology used</p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class={`px-3 py-1 ${tag.color} text-white text-sm rounded-full`}>{tag.label}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
