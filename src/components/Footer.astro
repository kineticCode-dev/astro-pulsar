---
import { SITE_CONFIG } from '../config';

const currentYear = new Date().getFullYear();

interface Props {
  showCopyright?: boolean;
  compact?: boolean;
}

const { showCopyright = true, compact = false } = Astro.props;
const paddingClass = compact ? 'py-2' : 'py-4';

// Social links configuration. `icon` is a Font Awesome 4 class; `svgPath`
// renders an inline SVG instead (FA4 has no X logo).
const socialLinks = [
  {
    name: 'GitHub',
    url: SITE_CONFIG.socialLinks.github ? `https://github.com/${SITE_CONFIG.socialLinks.github}` : null,
    icon: 'fa-github',
    svgPath: null,
    hoverColor: 'hover:text-gray-900 dark:hover:text-white',
  },
  {
    name: 'LinkedIn',
    url: SITE_CONFIG.socialLinks.linkedin ? 'https://www.linkedin.com' : null,
    icon: 'fa-linkedin',
    svgPath: null,
    hoverColor: 'hover:text-blue-600 dark:hover:text-blue-400',
  },
  {
    name: 'X',
    url: SITE_CONFIG.socialLinks.twitter ? 'https://x.com' : null,
    icon: null,
    svgPath:
      'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
    hoverColor: 'hover:text-gray-900 dark:hover:text-white',
  },
  {
    name: 'YouTube',
    url: SITE_CONFIG.socialLinks.youtube ? `https://www.youtube.com/c/${SITE_CONFIG.socialLinks.youtube}` : null,
    icon: 'fa-youtube-play',
    svgPath: null,
    hoverColor: 'hover:text-red-600 dark:hover:text-red-400',
  },
  {
    name: 'RSS',
    url: `${import.meta.env.BASE_URL}rss.xml`,
    icon: 'fa-rss',
    svgPath: null,
    hoverColor: 'hover:text-orange-500 dark:hover:text-orange-400',
  },
].filter(link => link.url); // Only show configured social links
---

<footer id="footer" class={`${paddingClass} bg-gray-50 dark:bg-gray-800 transition-colors duration-200`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap items-center gap-4">
    <!-- Social buttons -->
    {socialLinks.length > 0 && (
      <div aria-label="Social links">
        <ul class="flex items-center space-x-4 list-none">
          {socialLinks.map(link => (
            <li>
              <a
                href={link.url!}
                target="_blank"
                rel="noopener noreferrer"
                class={`text-gray-700 ${link.hoverColor} dark:text-gray-300 transition-colors duration-200`}
                title={link.name}
                aria-label={link.name}
              >
                {link.svgPath ? (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d={link.svgPath}></path>
                  </svg>
                ) : (
                  <i class={`fa ${link.icon} fa-lg`} aria-hidden="true"></i>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
    <!-- Social buttons end -->

    <!-- Copyright -->
    {showCopyright && (
      <div class="ml-auto text-gray-600 dark:text-gray-400 text-sm">
        Copyright © {currentYear}{' '}
        <a href={SITE_CONFIG.siteUrl} class="text-gray-900 hover:text-gray-600 dark:text-gray-100 dark:hover:text-gray-400 font-medium">{SITE_CONFIG.author}</a>
      </div>
    )}
  </div>
</footer>
