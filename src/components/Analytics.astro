---
// Google Analytics 4. Renders nothing outside production builds so dev and
// preview traffic never reaches the property.
import { SITE_CONFIG } from '../config';

interface Props {
  contentGroup?: string | undefined;
  author?: string | undefined;
  tags?: string[] | undefined;
}

const { contentGroup = 'page', author, tags } = Astro.props;
const GA_ID = SITE_CONFIG.googleAnalyticsId;
const enabled = import.meta.env.PROD && GA_ID && SITE_CONFIG.features.analytics;
---

{enabled && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID, contentGroup, author, tags }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());

      // Set before config so the first page_view already carries the property
      gtag('set', 'user_properties', {
        site_theme: localStorage.getItem('theme') === 'light' ? 'light' : 'dark',
      });

      const config = { content_group: contentGroup };
      if (author) config.post_author = author;
      if (tags && tags.length) config.post_tags = tags.slice(0, 5).join(',');
      gtag('config', GA_ID, config);
    </script>
  </>
)}
